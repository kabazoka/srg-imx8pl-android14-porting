 CONFIG_DRM_PANEL_SIMPLE=y
 CONFIG_ETHERNET=y
@@ -176,7 +177,7 @@ CONFIG_KEYBOARD_SNVS_PWRKEY=y
 CONFIG_L2TP=y
 CONFIG_LEDS_GPIO=y
 CONFIG_LEDS_PCA963X=y
-CONFIG_LEDS_PCA995X=y
+CONFIG_LEDS_PCA995X=m
 CONFIG_LEDS_PWM=y
 CONFIG_LOGO=y
 # CONFIG_LOGO_LINUX_MONO is not set
@@ -367,7 +368,7 @@ CONFIG_TIMER_IMX_SYS_CTR=y
 CONFIG_TIPC=y
 CONFIG_TOUCHSCREEN_ELAN=y
