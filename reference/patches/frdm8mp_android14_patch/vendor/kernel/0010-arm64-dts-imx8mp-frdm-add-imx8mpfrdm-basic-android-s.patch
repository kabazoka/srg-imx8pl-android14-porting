From a4da39ab2bc9dc21f86b394076ff74175b8e6d48 Mon Sep 17 00:00:00 2001
From: nxf77310 <rhody.ma@nxp.com>
Date: Fri, 18 Jul 2025 17:03:36 +0900
Subject: [PATCH 10/10] arm64: dts: imx8mp-frdm: add imx8mpfrdm basic android
 support

---
 .../dts/freescale/imx8mp-frdm-android.dtsi    | 72 +++++++++++++++++++
 arch/arm64/configs/imx8mp_gki.fragment        |  3 +
 arch/arm64/configs/imx_v8_android_defconfig   |  5 +-
 arch/arm64/configs/imx_v8_defconfig           |  3 +-
 4 files changed, 80 insertions(+), 3 deletions(-)
 create mode 100644 arch/arm64/boot/dts/freescale/imx8mp-frdm-android.dtsi

diff --git a/arch/arm64/boot/dts/freescale/imx8mp-frdm-android.dtsi b/arch/arm64/boot/dts/freescale/imx8mp-frdm-android.dtsi
new file mode 100644
index 000000000000..5a3a021eefef
--- /dev/null
+++ b/arch/arm64/boot/dts/freescale/imx8mp-frdm-android.dtsi
@@ -0,0 +1,72 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+/*
+ * Copyright 2022 NXP
+ */
+
+/ {
+	firmware {
+		android {
+			compatible = "android,firmware";
+			/* sd card node which used if androidboot.boot_device_root=mmcblk1 */
+			boot_devices_mmcblk1 = "soc@0/30800000.bus/30b50000.mmc";
+			/* emmc node which used if androidboot.boot_device_root=mmcblk2 */
+			boot_devices_mmcblk2 = "soc@0/30800000.bus/30b60000.mmc";
+			vbmeta {
+				/*we need use FirstStageMountVBootV2 if we enable avb*/
+				compatible = "android,vbmeta";
+				/*parts means the partition witch can be mount in first stage*/
+				parts = "vbmeta,dtbo,boot,init_boot,system,vendor,vendor_dlkm,product";
+			};
+		};
+	};
+
+	trusty {
+		compatible = "android,trusty-smc-v1";
+		ranges;
+		#address-cells = <2>;
+		#size-cells = <2>;
+		trusty-irq {
+			compatible = "android,trusty-irq-v1";
+			interrupt-ranges = < 0 15 0>;
+			ipi-range = <8 15 8>;
+		};
+		trusty-virtio {
+			compatible = "android,trusty-virtio-v1";
+		};
+		trusty-log {
+			compatible = "android,trusty-log-v1";
+		};
+	};
+};
+
+&{/reserved-memory/linux,cma} {
+	status = "disabled";
+};
+
+&resmem {
+	ramoops@94400000 {
+		compatible = "ramoops";
+		reg = <0 0x94400000 0 0x00100000>;
+		record-size     = <0x00020000>;
+		console-size    = <0x00020000>;
+		ftrace-size     = <0x00020000>;
+		pmsg-size       = <0x00020000>;
+        };
+	secure_region: secure {
+		 compatible = "imx-secure-ion-pool";
+		 reg = <0x0 0xE0000000 0 0x10000000>;
+	};
+};
+
+&lcdif1 {
+	trusty;
+	status = "okay";
+};
+
+&uart1 {
+	/delete-node/ bluetooth;
+};
+
+&vpumix_blk_ctl {
+	trusty;
+};
diff --git a/arch/arm64/configs/imx8mp_gki.fragment b/arch/arm64/configs/imx8mp_gki.fragment
index fd6bcad1742b..6bba4c2cd84a 100644
--- a/arch/arm64/configs/imx8mp_gki.fragment
+++ b/arch/arm64/configs/imx8mp_gki.fragment
@@ -113,6 +113,7 @@ CONFIG_RESET_IMX7=m
 CONFIG_IMX8M_BUSFREQ=m
 CONFIG_IMX_IRQSTEER=m
 CONFIG_GPIO_MXC=m
+CONFIG_GPIO_PCA953X=m
 CONFIG_TIMER_IMX_SYS_CTR=m
 
 CONFIG_FPGA=y
@@ -138,3 +139,5 @@ CONFIG_FSL_IMX8_DDR_PMU=m
 # CONFIG_SOC_IMX9 is not set
 # CONFIG_MODULE_SIG_ALL is not set
 CONFIG_IMX_GKI_FIX=y
+CONFIG_GPIO_PCA953X_IRQ=y
+CONFIG_LEDS_PCA995X=m
