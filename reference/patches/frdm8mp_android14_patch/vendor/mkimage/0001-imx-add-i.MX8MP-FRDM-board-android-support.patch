From 978a9bd268d62f88fbbda7f335c6c0dfc2fe0739 Mon Sep 17 00:00:00 2001
From: nxf77310 <rhody.ma@nxp.com>
Date: Fri, 18 Jul 2025 17:15:18 +0900
Subject: [PATCH] imx: add i.MX8MP FRDM board android support

---
 iMX8M/soc.mak | 26 ++++++++++++++++++++++++++
 1 file changed, 26 insertions(+)

diff --git a/iMX8M/soc.mak b/iMX8M/soc.mak
index e7c762b..14260e7 100644
--- a/iMX8M/soc.mak
+++ b/iMX8M/soc.mak
@@ -163,6 +163,18 @@ u-boot.itb: $(dtb) $(supp_dtbs)
 	./mkimage_uboot -E -p $(FIT_EXTERNAL_POSITION) -f u-boot.its u-boot.itb
 	@rm -f u-boot.its $(dtb)
 
+dtb_frdm = frdm.dtb
+$(dtb_frdm):
+	./$(DTB_PREPROC) $(PLAT)-frdm.dtb $(dtb_frdm) $(dtbs)
+
+u-boot-frdm.itb:  $(dtb_frdm) $(supp_dtbs)
+	./$(PAD_IMAGE) $(TEE)
+	./$(PAD_IMAGE) bl31.bin
+	./$(PAD_IMAGE) u-boot-nodtb.bin $(dtb_frdm) $(supp_dtbs)
+	BL32=$(TEE) DEK_BLOB_LOAD_ADDR=$(DEK_BLOB_LOAD_ADDR) TEE_LOAD_ADDR=$(TEE_LOAD_ADDR) ATF_LOAD_ADDR=$(ATF_LOAD_ADDR) ../$(SOC_DIR)/mkimage_fit_atf.sh $(dtb_frdm) $(supp_dtbs) > u-boot-frdm.its
+	./mkimage_uboot -E -p $(FIT_EXTERNAL_POSITION) -f u-boot-frdm.its u-boot-frdm.itb
+	@rm -f u-boot.its $(dtb_frdm)
+
 dtb_ddr3l = valddr3l.dtb
 $(dtb_ddr3l):
 	./$(DTB_PREPROC) $(PLAT)-ddr3l-$(VAL_BOARD).dtb $(dtb_ddr3l) $(dtbs)
@@ -287,6 +299,13 @@ flash_evk_no_hdmi_dual_bootloader: $(MKIMG) u-boot-spl-ddr.bin u-boot.itb
 	./mkimage_imx8 -version $(VERSION) -fit -loader u-boot-spl-ddr.bin $(SPL_LOAD_ADDR) -out $(OUTIMG)
 	./mkimage_imx8 -fit_ivt u-boot.itb 0x40200000 0x0 -out u-boot-ivt.itb
 
+flash_frdm_no_hdmi: $(MKIMG) u-boot-spl-ddr.bin u-boot-frdm.itb
+	./mkimage_imx8 -version $(VERSION) -fit -loader u-boot-spl-ddr.bin $(SPL_LOAD_ADDR) -second_loader u-boot-frdm.itb 0x40200000 0x60000 -out $(OUTIMG)
+
+flash_frdm_no_hdmi_dual_bootloader: $(MKIMG) u-boot-spl-ddr.bin u-boot-frdm.itb
+	./mkimage_imx8 -version $(VERSION) -fit -loader u-boot-spl-ddr.bin $(SPL_LOAD_ADDR) -out $(OUTIMG)
+	./mkimage_imx8 -fit_ivt u-boot-frdm.itb 0x40200000 0x0 -out u-boot-ivt.itb
+
 flash_evk_no_hdmi_emmc_fastboot: $(MKIMG) u-boot-spl-ddr.bin u-boot.itb
 	./mkimage_imx8 -version $(VERSION) -dev emmc_fastboot -fit -loader u-boot-spl-ddr.bin $(SPL_LOAD_ADDR) -second_loader u-boot.itb 0x40200000 0x60000 -out $(OUTIMG)
 
@@ -331,6 +350,13 @@ print_fit_hab: u-boot-nodtb.bin bl31.bin $(dtb) $(supp_dtbs)
 	FIT_DATA_POS=$(FIT_EXTERNAL_POSITION) TEE_LOAD_ADDR=$(TEE_LOAD_ADDR) ATF_LOAD_ADDR=$(ATF_LOAD_ADDR) VERSION=$(VERSION) ../$(SOC_DIR)/print_fit_hab.sh $(PRINT_FIT_HAB_OFFSET) $(dtb) $(supp_dtbs)
 	@rm -f $(dtb)
 
+print_fit_hab_frdm: u-boot-nodtb.bin bl31.bin $(dtb_frdm) $(supp_dtbs)
+	./$(PAD_IMAGE) $(TEE)
+	./$(PAD_IMAGE) bl31.bin
+	./$(PAD_IMAGE) u-boot-nodtb.bin $(dtb_frdm) $(supp_dtbs)
+	FIT_DATA_POS=$(FIT_EXTERNAL_POSITION) TEE_LOAD_ADDR=$(TEE_LOAD_ADDR) ATF_LOAD_ADDR=$(ATF_LOAD_ADDR) VERSION=$(VERSION) ../$(SOC_DIR)/print_fit_hab.sh $(PRINT_FIT_HAB_OFFSET) $(dtb_frdm) $(supp_dtbs)
+	@rm -f $(dtb_frdm)
+
 print_fit_hab_ddr4: u-boot-nodtb.bin bl31.bin $(dtb_ddr4_evk) $(supp_dtbs)
 	./$(PAD_IMAGE) $(TEE)
 	./$(PAD_IMAGE) bl31.bin
-- 
2.34.1

